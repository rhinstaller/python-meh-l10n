#: ../meh/handler.py:195
msgid ""
"Use 'continue' command to quit the debugger and get back to the main menu"
msgstr ""
"Употребите 'continue' команду да напустите програм за отклањање грешака и "
"вратите се назад на главни мени"

#: ../meh/handler.py:211
msgid "Exit the shell to get back to the main menu"
msgstr "Изађите из љуске да се вратите у главни мени"

#: ../meh/ui/gui.py:176
msgid "_Exit"
msgstr "_Изађи"

#. short (one-char) answer meaning "yes"
#: ../meh/ui/text.py:75
msgid "y"
msgstr "д"

#. short (one-char) answer meaning "no"
#: ../meh/ui/text.py:78
msgid "n"
msgstr "н"

#: ../meh/ui/text.py:145
msgid "Save exception"
msgstr "Сачувај изузетак"

#: ../meh/ui/text.py:158 tmp/exception-dialog.glade.h:1
msgid "An unknown error has occurred"
msgstr "Непозната грешка се догодила"

#: ../meh/ui/text.py:161
msgid "Report Bug"
msgstr "Пријави бубу"

#: ../meh/ui/text.py:162
msgid "Run shell"
msgstr "Покрени љуску"

#: ../meh/ui/text.py:163
msgid "Quit"
msgstr "Изађи"

#: ../meh/ui/text.py:168
msgid "Debug"
msgstr "Отклони бубе"

#: ../meh/ui/text.py:173
msgid "What do you want to do now?"
msgstr "Шта желите сада да урадите?"

#: ../meh/ui/text.py:181
msgid "Please make your choice from above: "
msgstr "Направите ваш избор изнад: "

#: ../meh/ui/text.py:199
msgid "Hit ENTER to continue"
msgstr "Притисните УНЕСИ за наставак"

#: ../meh/ui/text.py:213
#, python-format
msgid "Are you sure you want to exit? [%(yes)s/%(no)s]"
msgstr "Да ли сте сигурни да желите да изађете? [%(yes)s/%(no)s]"

#: tmp/exception-dialog.glade.h:2
msgid ""
"This program has encountered an unknown error. You may\n"
"report the bug below or quit the program."
msgstr ""
"Овај програм је наишао на непознату грешку. Можете\n"
"пријавити грешку испод или изаћи из програма."

#: tmp/exception-dialog.glade.h:4
msgid "_Report Bug"
msgstr "_Пријави грешку"

#: tmp/exception-dialog.glade.h:5
msgid "_Quit"
msgstr "И_зађи"

#: tmp/exception-dialog.glade.h:6
msgid "The output below may help determine the cause of the error:"
msgstr "Излаз испод може помоћи у одређивању узрока грешке:"

#: tmp/exception-dialog.glade.h:7
msgid "'Debug' may take you to tty1."
msgstr "„Debug“ вас може одвести на tty1."

#: tmp/exception-dialog.glade.h:8
msgid "_Debug"
msgstr "_Уклањање грешака"

#: tmp/exception-dialog.glade.h:9
msgid "More _info..."
msgstr "Више _података..."

#: tmp/exception-dialog.glade.h:10
msgid "No additional info available."
msgstr "Нема доступних додатних података."
